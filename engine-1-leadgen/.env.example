# KI Katapult – Engine 1: Lead Generator
# Copy to .env and fill in your values

# Required: Google Gemini API key
# Without this, the app runs in demo mode with mock data
GOOGLE_API_KEY=

# App password (default: brainlancer2026)
APP_PASSWORD=brainlancer2026

# Session secret key (generate a secure random value for production)
SECRET_KEY=change-me-in-production

# Credits per session (default: 10)
CREDITS_PER_SESSION=10

# SQLite database path (default: leadgen.db in working directory)
DB_PATH=leadgen.db
